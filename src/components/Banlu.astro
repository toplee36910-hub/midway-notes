---
/**
 * Banlu.astro — 半路角色 SVG 组件
 * 
 * Props:
 *   pose: 'stand' | 'point' | 'walk' | 'squat' | 'sit' (default: 'stand')
 *   size: 'sm' | 'md' | 'lg' (default: 'md')
 *   animate: boolean (default: false)
 */

interface Props {
  pose?: 'stand' | 'point' | 'walk' | 'squat' | 'sit';
  size?: 'sm' | 'md' | 'lg';
  animate?: boolean;
}

const { pose = 'stand', size = 'md', animate = false } = Astro.props;

const sizeMap = { sm: 40, md: 80, lg: 160 };
const w = sizeMap[size];

// 手绘风格：用不规则贝塞尔曲线模拟铅笔抖动
// 帽子（所有姿态共享）— 微微歪斜的渔夫帽，不规则轮廓
const hatCrown = `
  M 34 28
  C 33 22, 38 16, 44 14
  C 48 13, 54 13, 58 14
  C 64 16, 68 21, 67 28
`;

const hatBrim = `
  M 22 29
  C 23 27, 30 26, 34 28
  C 34 28, 50 26, 67 28
  C 71 26, 77 27, 78 29
  C 79 31, 77 33, 74 34
  C 68 36, 56 37, 50 37
  C 44 37, 32 36, 26 34
  C 23 33, 21 31, 22 29
  Z
`;

// 帽檐下方阴影（实心黑色，遮住整张脸）
const faceShadow = `
  M 30 34
  C 32 33, 40 36, 50 36
  C 60 36, 68 33, 70 34
  L 70 42
  C 68 44, 60 46, 50 46
  C 40 46, 32 44, 30 42
  Z
`;

// 头（不规则圆，手绘感）
const head = `
  M 50 26
  C 50 16, 40 10, 36 14
  C 30 18, 30 28, 34 32
  C 34 32, 30 36, 30 42
  M 50 26
  C 50 16, 60 10, 64 14
  C 70 18, 70 28, 66 32
  C 66 32, 70 36, 70 42
`;

// 各姿态身体 — 手绘曲线，非直线
const bodies: Record<string, string> = {
  stand: `
    M 42 46 C 40 52, 38 60, 36 68
    M 58 46 C 60 52, 62 60, 64 68
    M 36 68 C 34 70, 32 72, 34 74
    M 64 68 C 66 70, 68 72, 66 74
    M 44 74 C 42 80, 40 88, 38 94
    M 56 74 C 58 80, 60 88, 62 94
    M 38 94 C 36 95, 34 96, 33 95
    M 62 94 C 64 95, 66 96, 67 95
  `,
  point: `
    M 42 46 C 38 48, 28 48, 16 46
    M 58 46 C 60 52, 62 60, 64 68
    M 16 46 C 14 45, 12 44, 10 44
    M 64 68 C 66 70, 68 72, 66 74
    M 44 74 C 42 80, 40 88, 38 94
    M 56 74 C 58 80, 60 88, 62 94
    M 38 94 C 36 95, 34 96, 33 95
    M 62 94 C 64 95, 66 96, 67 95
  `,
  walk: `
    M 42 46 C 40 52, 38 58, 36 64
    M 58 46 C 60 50, 62 56, 66 62
    M 36 64 C 34 66, 33 68, 34 69
    M 66 62 C 68 64, 69 66, 68 67
    M 44 74 C 40 80, 34 88, 30 94
    M 56 74 C 60 80, 66 86, 70 92
    M 30 94 C 28 95, 26 96, 25 95
    M 70 92 C 72 93, 74 94, 75 93
  `,
  squat: `
    M 42 46 C 38 44, 34 42, 32 40
    M 58 46 C 62 44, 66 42, 68 40
    M 32 40 C 30 39, 28 38, 27 39
    M 68 40 C 70 39, 72 38, 73 39
    M 44 56 C 40 62, 34 70, 30 76
    M 56 56 C 60 62, 66 70, 70 76
    M 30 76 C 28 78, 26 80, 25 79
    M 70 76 C 72 78, 74 80, 75 79
  `,
  sit: `
    M 42 46 C 40 52, 38 58, 36 64
    M 58 46 C 60 52, 62 58, 64 64
    M 36 64 C 34 66, 33 67, 34 68
    M 64 64 C 66 66, 67 67, 66 68
    M 44 68 C 40 72, 34 76, 30 78
    M 56 68 C 60 72, 66 76, 70 78
    M 30 78 C 28 80, 28 86, 30 90
    M 70 78 C 72 80, 72 86, 70 90
  `,
};

const animClass = animate ? 'banlu-animate' : '';
const animStyle = animate ? `
  @keyframes banlu-walk {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-2px); }
  }
  @keyframes banlu-enter {
    from { opacity: 0; transform: translateX(20px); }
    to { opacity: 1; transform: translateX(0); }
  }
  .banlu-animate {
    animation: banlu-enter 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
  }
  @media (prefers-reduced-motion: reduce) {
    .banlu-animate { animation: none; opacity: 1; }
  }
` : '';
---

<svg
  class:list={['banlu', animClass, `banlu-${pose}`, `banlu-${size}`]}
  viewBox="0 0 100 100"
  width={w}
  height={w}
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  role="img"
>
  {animStyle && <style>{animStyle}</style>}
  
  <g
    fill="none"
    stroke="currentColor"
    stroke-width="2.2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <!-- 帽子冠（不规则弧线） -->
    <path d={hatCrown} />
    
    <!-- 帽檐（有机闭合曲线） -->
    <path d={hatBrim} />
    
    <!-- 帽檐下方阴影（实心黑色，遮住脸） -->
    <path d={faceShadow} fill="currentColor" stroke="none" />
    
    <!-- 身体 -->
    <path d={bodies[pose]} />
  </g>
</svg>

<style>
  .banlu {
    display: inline-block;
    vertical-align: middle;
  }
  .banlu-sm { width: 40px; height: 40px; }
  .banlu-md { width: 80px; height: 80px; }
  .banlu-lg { width: 160px; height: 160px; }
</style>
