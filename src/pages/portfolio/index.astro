---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('portfolio');
const sorted = entries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const statusClass: Record<string, string> = {
  '已交付': 'status-delivered',
  '进行中': 'status-in-progress',
  '规划中': 'status-planned',
};
---

<BaseLayout title="做过的事">
  <section class="hero">
    <h1 class="hero-title">
      <span class="accent">&gt;_</span> 做过的事
    </h1>
    <p class="hero-subtitle">
      已交付的商业项目与案例展示。部分客户信息因保密协议已做脱敏处理。
    </p>
  </section>

  <div class="portfolio-grid">
    {sorted.map((entry) => (
      <article class="portfolio-card">
        <div class="portfolio-card-header">
          <h2 class="portfolio-card-title">{entry.data.title}</h2>
          <span class={`status-badge ${statusClass[entry.data.status]}`}>
            {entry.data.status}
          </span>
        </div>
        <div class="portfolio-card-meta">
          <span class="portfolio-client">{entry.data.client || '保密'}</span>
          <span class="portfolio-date">{entry.data.date.toISOString().split('T')[0]}</span>
        </div>
        <p class="portfolio-card-summary">{entry.data.summary}</p>
        {entry.data.tags && entry.data.tags.length > 0 && (
          <div class="portfolio-card-tags">
            {entry.data.tags.map((t: string) => <span class="tag">{t}</span>)}
          </div>
        )}
      </article>
    ))}
  </div>

  {sorted.length === 0 && (
    <p class="portfolio-empty">暂无案例，敬请期待。</p>
  )}
</BaseLayout>

<style>
  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
  }

  .portfolio-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
    transition: border-color 0.2s, box-shadow 0.2s;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .portfolio-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 16px var(--color-card-shadow);
  }

  .portfolio-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--spacing-sm);
  }

  .portfolio-card-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.3;
  }

  .status-badge {
    font-size: 0.72rem;
    font-family: var(--font-mono);
    font-weight: 500;
    padding: 0.2em 0.6em;
    border-radius: 4px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .status-delivered {
    background: #dcfce7;
    color: #166534;
  }

  html.dark .status-delivered {
    background: #14532d;
    color: #86efac;
  }

  .status-in-progress {
    background: #dbeafe;
    color: #1e40af;
  }

  html.dark .status-in-progress {
    background: #1e3a5f;
    color: #93c5fd;
  }

  .status-planned {
    background: var(--color-tag-bg);
    color: var(--color-text-secondary);
  }

  .portfolio-card-meta {
    display: flex;
    gap: var(--spacing-md);
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
  }

  .portfolio-client::before {
    content: '';
  }

  .portfolio-card-summary {
    font-size: 0.88rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .portfolio-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
    margin-top: auto;
    padding-top: var(--spacing-sm);
  }

  .portfolio-empty {
    color: var(--color-text-secondary);
    text-align: center;
    padding: var(--spacing-xl) 0;
    font-style: italic;
  }

  @media (max-width: 640px) {
    .portfolio-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
