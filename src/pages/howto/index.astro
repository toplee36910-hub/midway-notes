---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('howto');
const sorted = entries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="怎么干的">
  <h1 class="category-title">怎么干的 — 端到端工作流、方法论、工具拆解</h1>
  <ul class="article-list">
    {sorted.map((entry) => (
      <li class="article-item">
        <h2><a href={`/howto/${entry.id}`}>{entry.data.title}</a></h2>
        <div class="article-meta">
          {entry.data.date.toISOString().split('T')[0]}
          {entry.data.tags?.map(t => <span class="tag">{t}</span>)}
        </div>
        <p class="article-summary">{entry.data.summary}</p>
      </li>
    ))}
  </ul>
</BaseLayout>
