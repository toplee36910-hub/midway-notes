---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('projects');
const sorted = entries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="做了啥">
  <h1 class="category-title">做了啥 — 完整项目交付复盘，有数据有时间线</h1>
  <ul class="article-list">
    {sorted.map((entry) => (
      <li class="article-item">
        <h2><a href={`/projects/${entry.id}`}>{entry.data.title}</a></h2>
        <div class="article-meta">
          {entry.data.date.toISOString().split('T')[0]}
          {entry.data.tags?.map(t => <span class="tag">{t}</span>)}
        </div>
        <p class="article-summary">{entry.data.summary}</p>
      </li>
    ))}
  </ul>
</BaseLayout>
